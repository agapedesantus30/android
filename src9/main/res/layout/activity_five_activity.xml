<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:orientation="horizontal"
    android:gravity="center"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context="edu.ggc.lutz.diceroller_solution.MainActivity">

    <LinearLayout
        android:layout_width="196dp"
        android:layout_height="match_parent"
        android:orientation="vertical">

        <ImageView
            android:id="@+id/dOne"
            android:layout_width="212dp"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:contentDescription="@string/dice_one"
            android:src="@drawable/dice_4"
            android:tint="@color/colorDice" />

        <ImageView
            android:id="@+id/dTwo"
            android:layout_width="212dp"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:contentDescription="@string/dice_one"
            android:src="@drawable/dice_1"
            android:tint="@color/colorDice" />

        <ImageView
            android:id="@+id/dThree"
            android:layout_width="212dp"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:contentDescription="@string/dice_one"
            android:src="@drawable/dice_2"
            android:tint="@color/colorDice" />

    </LinearLayout>

    <LinearLayout
        android:orientation="vertical"
        android:layout_width="match_parent"
        android:layout_height="match_parent">

        <ImageView
            android:id="@+id/dFour"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:contentDescription="@string/dice_one"
            android:tint="@color/colorDice"
            android:src="@drawable/dice_3" />

        <ImageView
            android:id="@+id/dFive"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:contentDescription="@string/dice_one"
            android:tint="@color/colorDice"
            android:src="@drawable/dice_4" />

    </LinearLayout>

</LinearLayout>