<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    package="edu.ggc.lutz.dicenotation">

    <application
        android:allowBackup="true"
        android:icon="@mipmap/ic_launcher_rpgdice"
        android:label="@string/app_name"
        android:roundIcon="@mipmap/ic_launcher_rpgdice_round"
        android:supportsRtl="true"
        android:theme="@style/AppTheme">
        <activity
            android:name="edu.ggc.lutz.dicenotation.ListActivity"
            android:label="@string/app_name"
            android:theme="@style/AppTheme.NoActionBar">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />

                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>
        <activity
            android:name="edu.ggc.lutz.dicenotation.DetailActivity"
            android:label="@string/title_item_detail"
            android:parentActivityName="edu.ggc.lutz.dicenotation.ListActivity"
            android:theme="@style/AppTheme.NoActionBar">
            <meta-data
                android:name="android.support.PARENT_ACTIVITY"
                android:value="edu.ggc.lutz.dicenotation.ListActivity" />
        </activity>
        <activity android:name="edu.ggc.lutz.dicenotation.AboutActivity"></activity>
    </application>

</manifest>